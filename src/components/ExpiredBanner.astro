---
const { pubDatetime, expiryDays = 30 } = Astro.props;
const now = new Date();
const pubDate = new Date(pubDatetime);

// Calculate integer days difference
const daysDiff = Math.floor((now.getTime() - pubDate.getTime()) / (1000 * 3600 * 24));

// Check if expired
const isExpired = daysDiff > expiryDays;
---

{isExpired && (
  <div class="expired-banner">
    This article was published on {pubDate.toLocaleDateString()}, {daysDiff} days ago. Content may be outdated.
  </div>
)}

<style> 
.expired-banner {
  background-color: #ffcc00; /* Yellow background */
  color: #333; /* Dark text */
  font-size: 1rem;
  padding: 10px;
  border-radius: 5px;
  border: 1px solid #e6a800; /* Dark yellow border */
  text-align: center;
  font-weight: bold;
  margin-top: 20px;
}
</style>
