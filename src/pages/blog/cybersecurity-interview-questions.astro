---
// src/pages/blog/cybersecurity-interview-questions.astro
import Layout from '../../layouts/BlogLayout.astro';
import { InterviewLayout } from '../../components/cybersec-qa/InterviewLayout';
import { interviewQuestions } from '../../data/interview-questions';
---

<Layout title="🔐 100+ Cybersecurity Interview Questions" description="Master your cybersecurity interview with 100+ real questions">
  <main class="prose max-w-none">
    <h1>🔐 100+ Cybersecurity Interview Questions</h1>
    <p class="lead"><strong>100+ real interview questions</strong> from top tech companies including Google, Amazon, Microsoft, and CrowdStrike</p>
    
    <InterviewLayout questions={interviewQuestions} client:load />
    
    <hr />
    
    <h2>🎯 Study Tips</h2>
    <ul>
      <li><strong>Practice explaining aloud</strong> - Interviewers want reasoning, not memorization</li>
      <li><strong>Connect concepts</strong> - Show how topics relate (e.g., XSS → session hijacking)</li>
      <li><strong>Hands-on practice</strong> - Use TryHackMe or HackTheBox</li>
      <li><strong>Track progress</strong> - Use the progress tracker above</li>
    </ul>
    
    <h2>📚 Recommended Resources</h2>
    <ul>
      <li><a href="https://tryhackme.com">TryHackMe</a> - Guided cybersecurity labs</li>
      <li><a href="https://hackthebox.com">HackTheBox</a> - Realistic penetration testing</li>
      <li><a href="https://portswigger.net/web-security">PortSwigger Academy</a> - Free web security labs</li>
      <li><a href="https://overthewire.org">OverTheWire</a> - Linux and network wargames</li>
    </ul>
    
    <div class="success-box">
      <h3>🎉 Good Luck with Your Interview!</h3>
      <p>Remember: Interviewers value problem-solving ability over perfect answers. Think aloud, ask clarifying questions, and show your passion for security.</p>
    </div>
  </main>
</Layout>

<style>
  .success-box {
    background: #c6f6d5;
    border: 1px solid #9ae6b4;
    padding: 1.5rem;
    border-radius: 8px;
    margin: 2rem 0;
    text-align: center;
  }
  
  .lead {
    font-size: 1.2rem;
    margin-bottom: 2rem;
  }
</style>
